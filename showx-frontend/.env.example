# =========================================================================
# SHOWX FRONTEND CONFIGURATION TEMPLATE (.env.example)
# Copy this template to a new local file named '.env' and fill in your values.
# =========================================================================

# The URL address where your local Vite frontend development server runs
VITE_APP_URL=http://localhost:5173/

# The URL address pointing to your local Node.js/Express backend server API path
VITE_API_BASE_URL=http://localhost:5000/api

# Your public Razorpay sandbox identifier key string
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX